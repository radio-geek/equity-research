# OpenAI (required for research and report)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# PostgreSQL (required)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/equity_research

# Google OAuth2 (required for user auth)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# JWT secret (required — generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# Web search: OpenAI Responses API (built-in) is used by default. Optional fallback:
# TAVILY_API_KEY=  # get key at https://tavily.com if Responses API is unavailable

# Optional: override paths (defaults: . for cwd, reports/ for PDFs)
# REPORTS_DIR=reports
# NSE_DOWNLOAD_FOLDER=./.nse_cache

# Optional: LangSmith – visualize graph runs at https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls__...   # get key at https://smith.langchain.com
# LANGSMITH_PROJECT=equity-research   # default: "default"
