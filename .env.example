# OpenAI (required for research and report)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# PostgreSQL (required)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/equity_research

# Google OAuth2 (required for user auth)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated extra browser origins allowed by CORS (production site, preview URLs, etc.).
# Example: ADDITIONAL_CORS_ORIGINS=https://www.example.com,https://example.com
# ADDITIONAL_CORS_ORIGINS=

# JWT secret (required — generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# Web search: OpenAI Responses API (built-in) is used by default. Optional fallback:
# TAVILY_API_KEY=  # get key at https://tavily.com if Responses API is unavailable

# Optional: override paths (defaults: . for cwd, reports/ for PDFs)
# REPORTS_DIR=reports
# NSE_DOWNLOAD_FOLDER=./.nse_cache

# Optional: PDF via Playwright – path to Chromium binary (Linux deploy uses /opt/chromium/chromium; local uses Playwright install)
# CHROMIUM_PATH=/opt/chromium/chromium
# Optional: force Playwright browser dir (app auto-uses ./playwright-browsers when a chromium revision dir exists)
# PLAYWRIGHT_BROWSERS_PATH=/opt/render/project/playwright-browsers

# Optional: LangSmith – visualize graph runs at https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls__...   # get key at https://smith.langchain.com
# LANGSMITH_PROJECT=equity-research   # default: "default"
