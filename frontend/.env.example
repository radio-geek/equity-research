# Optional: API base URL (default: same origin; Vite dev proxy forwards /api to backend)
# VITE_API_URL=http://localhost:8000

# Optional: Umami analytics (free self-hosted or cloud hobby tier). Leave unset to disable.
# Cloud: https://cloud.umami.is  |  Self-hosted: your Umami instance URL
# VITE_UMAMI_URL=https://cloud.umami.is
# VITE_UMAMI_WEBSITE_ID=your-website-id
